[resource]
script = ExtResource("1_ajpsb")
cinematic_title = "Conversacion_Mago_Villano"
texts = Array[String](["Malvado caballero, antes de destruir este lugar permitame mencionarle un objeto cuyo valor le convertira en el hombre mas poderoso del mundo", "Dicho objeto se encuentra bajo las montañas que nos rodean, encuentralo y no necesitaras cavar bajo esta  tierra.", "Villano: Si lo que dices es cierto aceptare vuestra oferta, con una condicion. ", "Villano: Que sea un hombre joven y sin experiencia quien encuentre dicho objeto y lo traiga frente a mi."])
