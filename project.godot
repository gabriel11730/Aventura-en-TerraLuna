;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Aventura_en_Terra_Luna_2"
config/version="1.0.0"
run/main_scene="uid://ngm8hcg4id05"
config/quit_on_go_back=false
config/features=PackedStringArray("4.4", "GL Compatibility")
run/max_fps=60
boot_splash/image="uid://cyxblsavecpdl"
config/icon="uid://brvqxxwkaqk1j"
config/windows_native_icon="res://favicon.ico"

[autoload]

GameState="*res://Scripts/Globales/GameState.gd"
SonidoGlobalMenus="*res://Scenes/Menus/SonidoGlobal_Menus.tscn"
LoadSavedGame="*res://Scripts/Globales/SaveSystem/LoadSavedGame.gd"
TablaDePuntuaciones="*res://Scripts/Globales/TablaDePuntuaciones.gd"
SilentWolf="*res://addons/silent_wolf/SilentWolf.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[editor]

naming/scene_name_casing=1
naming/script_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/silent_wolf/plugin.cfg")

[global_group]

Personaje="Grupo relacionado con el personaje"
Enemy=""
GameEvents=""
Eliminar=""
Coins=""

